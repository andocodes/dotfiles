#!/bin/sh
set -eu

usage() {
  cat <<'USAGE'
Usage: sh scripts/bootstrap [--profile full|minimal]
USAGE
}

validate_profile() {
  case "$1" in
    full|minimal) ;;
    *)
      echo "invalid profile: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
}

profile="full"
while [ "$#" -gt 0 ]; do
  case "$1" in
    --profile)
      profile="${2:?missing profile value}"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

validate_profile "$profile"

have() {
  command -v "$1" >/dev/null 2>&1
}

write_managed_config() {
  cat <<EOF
[data]
profile = "$profile"
role = "workstation"

[data.features]
gui = $gui
docker = $docker
ai = $ai
k8s = $k8s
yazi = $yazi
tailscale = $tailscale
tailscale-ssh = $tailscale_ssh
EOF
}

strip_managed_config() {
  awk '
    /^\[data([.][^]]+)?\]$/ {
      skip = 1
      next
    }
    /^\[/ {
      skip = 0
    }
    !skip {
      print
    }
  ' "$1"
}

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root=$(CDPATH= cd -- "$script_dir/.." && pwd)

if ! have git; then
  echo "git is required before bootstrap" >&2
  exit 1
fi

if ! have chezmoi; then
  mkdir -p "$HOME/.local/bin"
  case "$(uname -s)" in
    Darwin)
      if ! have brew; then
        echo "Homebrew is required on macOS before bootstrap" >&2
        exit 1
      fi
      brew install chezmoi
      ;;
    *)
      if ! have curl && ! have wget; then
        echo "curl or wget is required before bootstrap" >&2
        exit 1
      fi

      if have curl; then
        sh -c "$(curl -fsLS get.chezmoi.io)" -- -b "$HOME/.local/bin"
      else
        wget -qO- get.chezmoi.io | sh -s -- -b "$HOME/.local/bin"
      fi
      PATH="$HOME/.local/bin:$PATH"
      ;;
  esac
fi

config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
chezmoi_config_dir="$config_home/chezmoi"
chezmoi_config_file="$chezmoi_config_dir/chezmoi.toml"
mkdir -p "$chezmoi_config_dir"

if [ "$profile" = "minimal" ]; then
  gui=false
  docker=false
  ai=false
  k8s=false
  yazi=false
  tailscale=false
  tailscale_ssh=false
else
  gui=true
  docker=true
  ai=true
  k8s=true
  yazi=true
  tailscale=true
  tailscale_ssh=false
fi

tmp_config=$(mktemp "${TMPDIR:-/tmp}/chezmoi-config.XXXXXX")
trap 'rm -f "$tmp_config"' EXIT HUP INT TERM

if [ -f "$chezmoi_config_file" ]; then
  strip_managed_config "$chezmoi_config_file" > "$tmp_config"
else
  : > "$tmp_config"
fi

if [ -s "$tmp_config" ]; then
  printf '\n' >> "$tmp_config"
fi
write_managed_config >> "$tmp_config"
mv "$tmp_config" "$chezmoi_config_file"
trap - EXIT HUP INT TERM

chezmoi init --apply "$repo_root"
sh "$script_dir/doctor" --profile "$profile" --dry-run
